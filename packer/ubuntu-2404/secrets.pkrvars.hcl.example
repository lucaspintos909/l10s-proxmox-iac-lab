# ─── Packer Variables ────────────────────────────────────
# Copy this file to secrets.pkrvars.hcl and fill in your values.
# The .pkrvars.hcl file is gitignored — never commit credentials.

proxmox_api_url          = "https://10.0.0.1:8006/api2/json"
proxmox_api_token_id     = "root@pam!packer-token"
proxmox_api_token_secret = "CHANGE-ME-your-api-token-secret"
proxmox_node             = "pve"
ssh_public_key           = "ssh-ed25519 AAAA... tu-clave-publica-aqui"
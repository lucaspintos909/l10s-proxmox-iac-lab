# ─── Cloudflare Tunnel ────────────────────────────────
# Obtené este token desde:
# Cloudflare Dashboard → Zero Trust → Networks → Tunnels → Create → Cloudflared → Token
cloudflare_tunnel_token: "CHANGE-ME"

# ─── Cloudflare DNS API Token ─────────────────────────
# Necesario para que Traefik valide el dominio vía DNS Challenge (certificados wildcard).
# Cloudflare Dashboard → My Profile → API Tokens → Create Token → Zone:DNS:Edit
cloudflare_dns_api_token: "CHANGE-ME"

# ─── Traefik Dashboard BasicAuth ──────────────────────
# Protege el dashboard con usuario y contraseña.
# Generá tu hash con: htpasswd -nB admin
# IMPORTANTE: Los signos $ deben estar escapados como $$ para Docker Compose.
traefik_dashboard_auth: "admin:$$2y$$05$$CHANGE_ME_WITH_HTPASSWD_HASH"

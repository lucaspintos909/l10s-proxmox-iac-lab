# Traefik Static Configuration
# Managed by Ansible — do not edit manually.

api:
  dashboard: true
  insecure: true

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"

providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    network: "{{ docker_network }}"
  file:
    directory: /etc/traefik/config
    watch: true

log:
  level: INFO
